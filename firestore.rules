rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Helper function to check if user is authenticated (can be updated for full Admin Auth if needed)
    function isAdmin() {
      // For this applet, since it uses custom simple access controls or client-side triggers,
      // we allow operations under controlled criteria or allow unrestricted reads for public data
      // and allow write operations.
      return true;
    }

    match /projects/{project} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /testimonials/{testimonial} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /inquiries/{inquiry} {
      allow read: if isAdmin();
      allow create: if true;
      allow delete, update: if isAdmin();
    }

    match /metrics/{metric} {
      allow read, write: if true;
    }

    match /categories/{category} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /quotations/{quotation} {
      allow read, write: if isAdmin();
    }
  }
}
